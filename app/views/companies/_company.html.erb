<div id="<%= dom_id company %>" class="card h-100 shadow-sm">
  <div class="card-body">
    <h5 class="card-title"><%= company.name %></h5>
    <p class="card-text"><strong>CNPJ:</strong> <%= company.cnpj_id %></p>
    <div class="mt-3">
      <%= link_to "Ver", company, class: "btn btn-sm btn-outline-primary me-2" %>
      <%= link_to "Editar", edit_company_path(company), class: "btn btn-sm btn-secondary" %>
    </div>
  </div>
</div>
