<h1 class="mb-4">📊 Histórico de Movimentações</h1>

<div class="row">
  <div class="col-md-12">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">Todas as Transações de Estoque</h5>
      </div>
      <div class="card-body">
        <% if @movements.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead class="table-light">
                <tr>
                  <th>Data</th>
                  <th>Item</th>
                  <th>Tipo de Movimentação</th>
                  <th class="text-end">Quantidade</th>
                  <th>Detalhes</th>
                  <th>Referência</th>
                </tr>
              </thead>
              <tbody>
                <% @movements.each do |movement| %>
                  <tr>
                    <td class="align-middle">
                      <small><strong><%= movement.created_at.strftime("%d/%m/%Y") %></strong><br><%= movement.created_at.strftime("%H:%M:%S") %></small>
                    </td>
                    <td class="align-middle">
                      <% if movement.item %>
                        <strong><%= movement.item.name %></strong><br>
                        <small class="text-muted">Preço: R$ <%= number_with_precision(movement.item.price, precision: 2) %></small>
                      <% else %>
                        <span class="text-muted">Item deletado</span>
                      <% end %>
                    </td>
                    <td class="align-middle">
                      <% if movement.movement_type == "compra" %>
                        <span class="badge bg-success">🔹 Entrada (Compra)</span>
                      <% else %>
                        <span class="badge bg-danger">🔸 Saída (Venda)</span>
                      <% end %>
                    </td>
                    <td class="text-end align-middle">
                      <% if movement.movement_type == "compra" %>
                        <span class="text-success">
                          <strong>+ <%= movement.quantity_change %> un</strong>
                        </span>
                      <% else %>
                        <span class="text-danger">
                          <strong>- <%= movement.quantity_change %> un</strong>
                        </span>
                      <% end %>
                    </td>
                    <td class="align-middle">
                      <small>
                        <% if movement.notes %>
                          <%= truncate(movement.notes, length: 50) %>
                        <% else %>
                          <span class="text-muted">-</span>
                        <% end %>
                      </small>
                    </td>
                    <td class="align-middle">
                      <% if movement.movement_type == "compra" && movement.purchase %>
                        <small class="badge bg-info">
                          Compra #<%= movement.purchase_id %>
                        </small>
                      <% elsif movement.movement_type == "venda" && movement.sale %>
                        <small class="badge bg-warning text-dark">
                          Venda #<%= movement.sale_id %>
                        </small>
                      <% else %>
                        <small class="text-muted">-</small>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Pagination if enabled -->
          <% if @movements.respond_to?(:total_pages) %>
            <nav aria-label="Page navigation" class="mt-4">
              <ul class="pagination justify-content-center">
                <%= paginate @movements %>
              </ul>
            </nav>
          <% end %>
        <% else %>
          <div class="alert alert-info mb-0">
            <strong>Nenhuma movimentação registrada</strong><br>
            Quando você fizer compras ou vendas, elas aparecerão aqui.
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mt-4">
  <div class="row">
    <div class="col">
      <%= link_to "← Voltar ao Estoque", inventories_path, class: "btn btn-secondary" %>
    </div>
    <div class="col text-end">
      <%= link_to "📝 Nova Compra", new_purchase_path, class: "btn btn-primary" %>
      <%= link_to "🛒 Nova Venda", new_sale_path, class: "btn btn-success" %>
    </div>
  </div>
</div>
