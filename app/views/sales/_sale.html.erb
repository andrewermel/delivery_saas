<div id="<%= dom_id sale %>" class="card mb-2 shadow-sm">
  <div class="card-body d-flex justify-content-between align-items-start">
    <div>
      <h5 class="card-title"><%= sale.item.name %></h5>
      <p class="mb-1"><strong>Quantidade:</strong> <%= sale.quantity %>un</p>
      <p class="mb-1"><strong>Preço Unitário:</strong> <%= number_to_currency(sale.unit_price) %></p>
      <p class="mb-0"><strong>Total:</strong> <%= number_to_currency(sale.total_price) %></p>
      <small class="text-muted">Data: <%= I18n.l(sale.sale_date) %></small>
    </div>
    <div class="text-end">
      <%= link_to "Ver", sale, class: "btn btn-sm btn-outline-primary mb-2" %>
      <%= link_to "Editar", edit_sale_path(sale), class: "btn btn-sm btn-secondary mb-2" %>
      <%= link_to "Deletar", sale, method: :delete, data: { confirm: "Tem certeza?" }, class: "btn btn-sm btn-danger" %>
    </div>
  </div>
</div>
