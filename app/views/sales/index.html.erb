<% content_for :title, "Vendas" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3">Vendas</h1>
  <%= link_to "Nova venda", new_sale_path, class: "btn btn-primary" %>
</div>

<% if @sales.empty? %>
  <div class="alert alert-info">Nenhuma venda registrada.</div>
<% else %>
  <div id="sales" class="row g-3">
    <% @sales.each do |sale| %>
      <div class="col-lg-6">
        <%= render sale %>
      </div>
    <% end %>
  </div>
<% end %>
