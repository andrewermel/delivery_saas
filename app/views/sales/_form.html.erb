<%= form_with(model: sale, local: true, class: "row g-3", data: { controller: "sales-form", items_data: @items_data.to_json }) do |form| %>
  <% if sale.errors.any? %>
    <div class="alert alert-danger col-12">
      <h4><%= pluralize(sale.errors.count, "erro") %> ao salvar:</h4>
      <ul class="mb-0">
        <% sale.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="col-md-6">
    <%= form.label :item_id %>
    <%= form.select :item_id, options_from_collection_for_select(items, :id, :name, sale.item_id), { prompt: "Selecione um item" }, class: "form-control", data: { action: "sales-form#updatePrice", target: "sales-form.itemSelect" } %>
    <small class="form-text text-muted">Selecione o item que está sendo vendido</small>
  </div>

  <div class="col-md-6">
    <div>
      <%= form.label :unit_price, "Preço Unitário" %>
      <small class="form-text text-muted d-block mb-2">
        <span data-target="sales-form.suggestedPrice">Sugerido: R$ --</span>
      </small>
    </div>
    <%= form.number_field :unit_price, class: "form-control", placeholder: "Ex: 25.00", step: 0.01, data: { target: "sales-form.priceInput" } %>
    <small class="form-text text-muted">Preço de venda por unidade (2x o custo)</small>
  </div>

  <div class="col-md-6">
    <%= form.label :quantity, "Quantidade" %>
    <%= form.number_field :quantity, class: "form-control", placeholder: "Ex: 10" %>
    <small class="form-text text-muted">Quantidade em unidades</small>
  </div>

  <div class="col-md-6">
    <%= form.label :sale_date, "Data da Venda" %>
    <%= form.date_field :sale_date, class: "form-control", value: sale.sale_date || Date.today %>
  </div>

  <div class="col-12">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancelar", sales_path, class: "btn btn-secondary" %>
  </div>
<% end %>
