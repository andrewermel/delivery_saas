<!-- Hero Section -->
<div style="background: linear-gradient(135deg, #1a365d 0%, #2d5a8c 100%); color: white; padding: 5rem 2rem; margin: -2rem -1rem 0 -1rem;">
  <div class="container">
    <div class="row align-items-center min-vh-75">
      <div class="col-lg-6 mb-5 mb-lg-0">
        <h1 style="font-size: 3.5rem; font-weight: 800; margin-bottom: 1.5rem; line-height: 1.2;">
          Gerencie seu negócio com <span style="color: #f59e0b;">inteligência</span>
        </h1>
        <p style="font-size: 1.2rem; opacity: 0.95; margin-bottom: 2rem; line-height: 1.8;">
          Uma plataforma completa e intuitiva para controlar estoques, vendas, compras e gerar relatórios de forma simples e eficiente.
        </p>
        <div class="d-flex gap-3 flex-wrap">
          <%= link_to "Começar Agora", new_user_registration_path, class: "btn btn-warning btn-lg", style: "font-weight: 700; padding: 0.85rem 2rem;" %>
          <%= link_to "Já tenho conta", new_user_session_path, class: "btn btn-outline-light btn-lg", style: "font-weight: 700; padding: 0.85rem 2rem;" %>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card border-0 shadow-lg" style="background: rgba(255,255,255,0.95);">
          <div class="card-body p-5 text-center">
            <div style="font-size: 5rem; margin-bottom: 1.5rem; animation: float 3s ease-in-out infinite;">📊</div>
            <h3 class="card-title mb-3" style="color: #1a365d; font-weight: 700;">Controle Total</h3>
            <p class="card-text text-muted mb-0">
              Todas as informações que precisa em um único lugar, com dashboard intuitivo e relatórios detalhados.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  .min-vh-75 { min-height: 75vh; display: flex; align-items: center; }
</style>

<!-- Features Section -->
<div style="padding: 5rem 2rem; background-color: white;">
  <div class="container">
    <div style="text-align: center; margin-bottom: 3rem;">
