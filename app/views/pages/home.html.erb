            </p>
          </div>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100 text-center" style="border-top: 4px solid #0ea5e9; transition: all 0.3s ease;">
