<div class="container-fluid py-4">
  <!-- Header -->
  <div class="row mb-5">
    <div class="col-lg-8">
      <h1 class="display-6" style="font-weight: 800; color: #1a365d; margin-bottom: 0.5rem;">📊 Dashboard</h1>
      <p style="font-size: 1.1rem; color: #64748b;">
        Bem-vindo, <strong><%= @current_company.name %></strong> • <%= Date.today.strftime("%d de %B de %Y") %>
      </p>
    </div>
  </div>

  <!-- Filtro por Mês -->
  <div class="row mb-5">
    <div class="col-md-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <%= form_with url: dashboard_path, method: :get, local: true, class: "row g-3 align-items-end" do |f| %>
            <div class="col-auto">
              <label for="month" class="form-label fw-600">📅 Mês</label>
              <%= select_tag :month, options_for_select([
                ['Janeiro', 1], ['Fevereiro', 2], ['Março', 3], ['Abril', 4],
                ['Maio', 5], ['Junho', 6], ['Julho', 7], ['Agosto', 8],
                ['Setembro', 9], ['Outubro', 10], ['Novembro', 11], ['Dezembro', 12]
              ], @selected_month), class: "form-select", id: "month" %>
            </div>
            <div class="col-auto">
              <label for="year" class="form-label fw-600">Ano</label>
              <%= select_tag :year, options_for_select((2024..Date.today.year).map { |y| [y, y] }, @selected_year), class: "form-select", id: "year" %>
            </div>
            <div class="col-auto">
              <%= submit_tag "Filtrar", class: "btn btn-primary fw-700" %>
              <%= link_to "Limpar", dashboard_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Cards de Estatísticas -->
  <div class="row mb-5">
    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid #0ea5e9;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted"> Total Investido</h6>
          <h2 class="text-info fw-700">R$ <%= number_with_precision(@total_invested, precision: 2) %></h2>
          <small style="color: #64748b;">em estoque atual</small>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid #1a365d;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted"> Itens Cadastrados</h6>
          <h2 style="color: #1a365d; font-weight: 700;"><%= @total_items %></h2>
          <small style="color: #64748b;"><%= @total_quantity %> unidades</small>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid #10b981;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted"> Compras Total</h6>
          <h2 style="color: #10b981; font-weight: 700;"><%= @recent_purchases %></h2>
          <small style="color: #64748b;">registradas</small>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid #f59e0b;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted"> Vendas Total</h6>
          <h2 style="color: #f59e0b; font-weight: 700;"><%= @recent_sales %></h2>
          <small style="color: #64748b;">registradas</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Cards de Resumo Financeiro -->
  <div class="row mb-5">
    <h3 style="font-weight: 700; color: #1a365d; margin-bottom: 1.5rem;">💰 Resumo Financeiro - <%= Date.new(@selected_year, @selected_month, 1).strftime("%B/%Y") %></h3>
    
    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid #10b981;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted">Total de Compras</h6>
          <h2 style="color: #10b981; font-weight: 700;">R$ <%= number_with_precision(@total_purchases_month, precision: 2) %></h2>
          <small style="color: #64748b;">investido no período</small>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid #0ea5e9;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted;">Total de Vendas</h6>
          <h2 style="color: #0ea5e9; font-weight: 700;">R$ <%= number_with_precision(@total_sales_month, precision: 2) %></h2>
          <small style="color: #64748b;">receita no período</small>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid <%= @net_revenue >= 0 ? '#10b981' : '#ef4444' %>;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted;">Receita Líquida</h6>
          <h2 style="color: <%= @net_revenue >= 0 ? '#10b981' : '#ef4444' %>; font-weight: 700;">
            <%= @net_revenue >= 0 ? '+' : '' %>R$ <%= number_with_precision(@net_revenue.abs, precision: 2) %>
          </h2>
          <small style="color: #64748b;"><%= @net_revenue >= 0 ? 'Lucro' : 'Prejuízo' %></small>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-4">
      <div class="card border-0 shadow-sm h-100" style="border-top: 4px solid #f59e0b;">
        <div class="card-body p-4">
          <h6 class="card-title text-muted;">Margem de Lucro</h6>
          <% margin = @total_sales_month > 0 ? ((@net_revenue / @total_sales_month) * 100).round(2) : 0 %>
          <h2 style="color: <%= margin >= 0 ? '#10b981' : '#ef4444' %>; font-weight: 700;"><%= margin %>%</h2>
          <small style="color: #64748b;">de lucro sobre vendas</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Itens em Estoque -->
  <div class="row mb-5">
    <div class="col-md-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header" style="background: linear-gradient(135deg, #1a365d 0%, #2d5a8c 100%); color: white; border: none;">
          <h5 class="card-title mb-0" style="color: white;">📦 Itens em Estoque</h5>
        </div>
        <div class="card-body p-0">
          <% if @items_in_stock.any? %>
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead style="background-color: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                  <tr>
                    <th style="color: #1a365d; font-weight: 700; padding: 1.2rem;">Item</th>
                    <th class="text-end" style="color: #1a365d; font-weight: 700; padding: 1.2rem;">Quantidade</th>
                    <th class="text-end" style="color: #1a365d; font-weight: 700; padding: 1.2rem;">Preço Médio</th>
                    <th class="text-end" style="color: #1a365d; font-weight: 700; padding: 1.2rem;">Valor Total</th>
                  </tr>
                </thead>
                <tbody>
                  <% @items_in_stock.each do |item| %>
                    <tr style="border-bottom: 1px solid #e2e8f0;">
                      <td style="padding: 1.2rem;"><strong style="color: #1a365d;"><%= item.name %></strong></td>
                      <td class="text-end" style="padding: 1.2rem;">
                        <span class="badge" style="background: linear-gradient(135deg, #1a365d 0%, #2d5a8c 100%); color: white;"><%= item.quantity_in_stock %> un</span>
                      </td>
                      <td class="text-end" style="padding: 1.2rem; color: #10b981; font-weight: 600;">R$ <%= number_with_precision(item.price, precision: 2) %></td>
                      <td class="text-end" style="padding: 1.2rem;">
                        <strong style="color: #1a365d; font-size: 1.1rem;">R$ <%= number_with_precision((item.price.to_f * item.quantity_in_stock), precision: 2) %></strong>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div style="padding: 2rem; text-align: center; background-color: #f8fafc;">
              <p style="color: #64748b; margin: 0;">📦 Nenhum item em estoque</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Últimas Movimentações -->
  <div class="row">
    <div class="col-md-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header" style="background: linear-gradient(135deg, #1a365d 0%, #2d5a8c 100%); color: white; border: none;">
          <h5 class="card-title mb-0" style="color: white;">📝 Últimas Movimentações</h5>
        </div>
        <div class="card-body p-0">
          <% if @recent_movements.any? %>
            <div class="table-responsive">
              <table class="table table-hover mb-0 table-sm">
                <thead style="background-color: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                  <tr>
                    <th style="color: #1a365d; font-weight: 700; padding: 1rem;">Data</th>
                    <th style="color: #1a365d; font-weight: 700; padding: 1rem;">Item</th>
                    <th style="color: #1a365d; font-weight: 700; padding: 1rem;">Tipo</th>
                    <th class="text-end" style="color: #1a365d; font-weight: 700; padding: 1rem;">Quantidade</th>
                    <th class="text-end" style="color: #1a365d; font-weight: 700; padding: 1rem;">Valor</th>
                  </tr>
                </thead>
                <tbody>
                  <% @recent_movements.each do |movement| %>
                    <% 
                      # Determine link based on movement type
                      if movement.movement_type == "purchase" && movement.purchase
                        link_path = purchase_path(movement.purchase)
                      elsif movement.movement_type == "sale" && movement.sale
                        link_path = sale_path(movement.sale)
                      else
                        link_path = nil
                      end
                      
                      # Get REAL value from purchase or sale
                      value = if movement.movement_type == "purchase" && movement.purchase
                        movement.purchase.price.to_f
                      elsif movement.movement_type == "sale" && movement.sale
                        movement.sale.total_price.to_f
                      else
                        0
                      end
                    %>
                    <%= link_to dashboard_path, method: :get, onclick: "window.location.href='#{link_path}'; return false;" if link_path %>
                    <tr style="border-bottom: 1px solid #e2e8f0; <%= link_path ? 'cursor: pointer;' : '' %>" onmouseover="<%= link_path ? "this.style.backgroundColor='#f1f5f9'" : "" %>" onmouseout="<%= link_path ? "this.style.backgroundColor=''" : "" %>" onclick="<%= link_path ? "window.location.href='#{link_path}'" : "" %>">
                      <td style="padding: 1rem;"><small style="color: #64748b;"><strong><%= movement.created_at.strftime("%d/%m %H:%M") %></strong></small></td>
                      <td style="padding: 1rem;">
                        <small style="color: #1a365d; font-weight: 500;">
                          <% if movement.item %>
                            <strong><%= movement.item.name %></strong>
                          <% else %>
                            <span style="color: #64748b;">Item deletado</span>
                          <% end %>
                        </small>
                      </td>
                      <td style="padding: 1rem;">
                        <% if movement.movement_type == "purchase" %>
                          <span class="badge" style="background-color: #10b981; color: white;">Compra</span>
                        <% else %>
                          <span class="badge" style="background-color: #ef4444; color: white;">Venda</span>
                        <% end %>
                      </td>
                      <td class="text-end" style="padding: 1rem;">
                        <% if movement.movement_type == "purchase" %>
                          <span style="color: #10b981; font-weight: 600;">+<%= movement.quantity_change %> un</span>
                        <% else %>
                          <span style="color: #ef4444; font-weight: 600;"><%= movement.quantity_change %> un</span>
                        <% end %>
                      </td>
                      <td class="text-end" style="padding: 1rem;">
                        <strong style="color: #1a365d;">R$ <%= number_with_precision(value, precision: 2) %></strong>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div style="padding: 2rem; text-align: center; background-color: #f8fafc;">
              <p style="color: #64748b; margin: 0;">📝 Nenhuma movimentação registrada</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
