<div id="<%= dom_id purchase %>" class="card mb-2 shadow-sm">
  <div class="card-body d-flex justify-content-between align-items-start">
    <div>
      <h5 class="card-title"><%= purchase.item_name %></h5>
      <p class="mb-1"><strong>Preço:</strong> <%= number_to_currency(purchase.price) %></p>
      <p class="mb-0"><strong>Peso:</strong> <%= purchase.weight %></p>
    </div>
    <div class="text-end">
      <%= link_to "Ver", purchase, class: "btn btn-sm btn-outline-primary mb-2" %>
    </div>
  </div>
</div>
